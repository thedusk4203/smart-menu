DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5433/DATN
SECRET_KEY=change-me-in-env
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AI provider options:
# - disabled: no AI calls
# - lmstudio: local LM Studio OpenAI-compatible server
# - openai/deepseek: OpenAI-compatible cloud providers when AI_BASE_URL/API_KEY are set
AI_PROVIDER=disabled
AI_ENABLED=false

# LM Studio preset:
# 1) Open LM Studio, load a chat model.
# 2) Start the local server in the Developer tab, or run: lms server start
# 3) Set the values below.
# AI_PROVIDER=lmstudio
# AI_ENABLED=true
# AI_BASE_URL=http://localhost:1234/v1
# AI_API_KEY=lm-studio
# AI_MODEL=
# AI_TIMEOUT_SECONDS=60
