APP_ENV=development
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=smart_menu
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_DB=smart_menu
SECRET_KEY=replace-with-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# Google OAuth Web client ID; configure the allowed JavaScript origins in Google Cloud Console.
GOOGLE_CLIENT_ID=
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Bật sau khi catalog regular ingredients đã có purchase_increment và giá chuẩn hóa.

# AI provider options:
# - disabled: no AI calls
# - lmstudio: local LM Studio OpenAI-compatible server
# - openai/deepseek/google: OpenAI-compatible cloud providers when AI_BASE_URL/API_KEY are set
AI_PROVIDER=disabled
AI_ENABLED=false
AI_CONFIG_ENCRYPTION_KEY=

# LM Studio preset:
# 1) Open LM Studio, load a chat model.
# 2) Start the local server in the Developer tab, or run: lms server start
# 3) Set the values below.
# AI_PROVIDER=lmstudio
# AI_ENABLED=true
# AI_BASE_URL=http://localhost:1234/v1
# AI_API_KEY=lm-studio
# AI_MODEL=
# AI_TIMEOUT_SECONDS=60
